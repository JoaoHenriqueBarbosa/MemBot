# ---- Server ----
PORT=8081
HOST=localhost
JWT_SECRET=change_me
FRONTEND_URL=http://localhost:5173
DEFAULT_LANGUAGE=en

# ---- Database (Postgres) ----
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ai_jrnl
DB_USER=myuser
DB_PASSWORD=mypassword

# ---- LLM provider ----
# Explicit selection: "google" or "ollama".
# If unset, the app infers: GOOGLE_AI_API_KEY present => google, otherwise ollama.
LLM_PROVIDER=google

# Google (cloud) — used when LLM_PROVIDER=google
GOOGLE_AI_API_KEY=your-google-api-key
GOOGLE_MODEL=gemini-2.0-flash

# Ollama (local) — used when LLM_PROVIDER=ollama
MODEL_NAME=gemma2
OLLAMA_HOST=http://localhost:11434

# ---- Mail (optional, for email verification) ----
# MAIL_HOST=your-mail-host
# MAIL_PORT=587
# MAIL_USER=your-mail-user
# MAIL_PASSWORD=your-mail-password
